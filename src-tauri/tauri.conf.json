{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tidekeeper",
  "version": "1.0.0",
  "identifier": "com.tidekeeper.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tidekeeper",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src ipc: http://ipc.localhost ws: https://thunderstore.io https://api.nexusmods.com https://users.nexusmods.com; img-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    }
  }
}
